{
	"folders": [
		{
			"path": "."
		},
		{
			"path": "automation/ansible/homelab-ansible-inventory"
		}
	],
	"settings": {

		"ansible.python.interpreterPath": "/usr/bin/python3",
		"runTerminalCommand.commands": [
        {
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./common-ansible-run-playbook.sh --playbook ${PREFIX}{resource} --no-check; popd",
            "name": "Run Ansible Playbook",
						"group": "Ansible",
						"auto": true
        },
				{
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./common-ansible-run-playbook.sh --playbook ${PREFIX}{resource}; popd",
            "name": "Run Ansible Playbook with Check",
						"group": "Ansible",
						"auto": true
        },
				{
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./common-ansible-run-playbook.sh --playbook ${PREFIX}{resource} --no-check; popd",
            "name": "Run Ansible Playbook with edits",
						"group": "Ansible"
        },
				{
            "command": "$(git rev-parse --show-toplevel)/security/secret-mgmt/age-sops/sops.sh --encrypt {resource}",
            "name": "Encrypt file",
						"group": "SOPS",
						"auto": true
        },
				{
            "command": "$(git rev-parse --show-toplevel)/security/secret-mgmt/age-sops/sops.sh --encrypt-all-missing",
            "name": "Encrypt all missing files",
						"group": "SOPS",
						"auto": true
        },
				{
            "command": "$(git rev-parse --show-toplevel)/security/secret-mgmt/age-sops/sops.sh --reencrypt-all",
            "name": "Re-encrypt all files",
						"group": "SOPS",
						"auto": true
        },
				{
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./kickstart-app-project.sh --type docker --foldername ${PREFIX} --appname XXX; popd",
            "name": "Kickstart a docker project",
						"group": "Kickstart"
        },
				{
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./kickstart-app-project.sh --type k8s.helm --foldername ${PREFIX} --appname XXX; popd",
            "name": "Kickstart a k8s.helm project",
						"group": "Kickstart"
        },
				{
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./kickstart-app-project.sh --type k8s.truecharts --foldername ${PREFIX} --appname XXX; popd",
            "name": "Kickstart a k8s.truecharts project",
						"group": "Kickstart"
        },
				{
            "command": "PREFIX=$(git rev-parse --show-prefix); pushd $(git rev-parse --show-toplevel); ./kickstart-app-project.sh --type k8s.truecharts-local --foldername ${PREFIX} --appname XXX; popd",
            "name": "Kickstart a k8s.truecharts-local project",
						"group": "Kickstart"
        },
				{
            "command": "pushd $(git rev-parse --show-toplevel)/automation/ansible; ./deploy-ansible.sh; popd",
            "name": "Update Ansible Navigator",
						"group": "Ansible Navigator",
						"auto": true
        },
				{
            "command": "bash {resource}",
            "name": "Run the given script",
						"group": "Scripts",
						"auto": true
        }
    ]
	}
}
