services:
  tracearr:
    container_name: tracearr
    environment:
      DATABASE_POOL_MAX: 10
      LOG_LEVEL: info
      TZ: {{ timezone }}
    extra_hosts:
      - host.docker.internal:host-gateway
    healthcheck:
      interval: 30s
      retries: 3
      start_period: 60s
      test: ["CMD", "curl", "-f", "http://127.0.0.1:3000/health"]
      timeout: 10s
    hostname: {{ id }}-tracearr
    image: {{ requested_image_version['tracearr'] }}
    mem_limit: 3g
    ports:
      - {{ port_tracearr }}:3000
    restart: unless-stopped
    shm_size: 512mb
    ulimits:
      nofile:
        hard: 65536
        soft: 65536
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/tracearr_postgres:/data/postgres
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/tracearr_redis:/data/redis
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/tracearr_data:/data/tracearr
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/tracearr_backups:/data/backup
