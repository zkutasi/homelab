services:
  koito:
    container_name: koito
    environment:
      PGID: {{ ansible_user_gid }}
      PUID: {{ ansible_user_uid }}
      TZ: {{ timezone }}
    hostname: {{ id }}-koito
    image: {{ requested_image_version['koito'] }}
    ports:
      - {{ port_koito }}:4110
    restart: unless-stopped
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/data:/etc/koito
