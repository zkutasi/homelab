services:
  speedtest-tracker:
    container_name: speedtest-tracker
    environment:
      PUID: {{ ansible_user_uid }}
      PGID: {{ ansible_user_gid }}
      APP_KEY: {{ speedtest_tracker_app_key }}
      DB_CONNECTION: sqlite
      DISPLAY_TIMEZONE: {{ timezone }}
      SPEEDTEST_SCHEDULE: "{{ speedtest_tracker_schedule }}"
      TZ: {{ timezone }}
    healthcheck:
      test: curl -fSs http://localhost/api/healthcheck | jq -r .message || exit 1
      interval: 10s
      retries: 3
      start_period: 30s
      timeout: 10s
    hostname: {{ id }}-speedtest-tracker
    image: {{ requested_image_version['speedtest-tracker'] }}
    ports:
      - {{ port_speedtest_tracker_http }}:80
      - {{ port_speedtest_tracker_https }}:443
    restart: unless-stopped
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/config:/config
