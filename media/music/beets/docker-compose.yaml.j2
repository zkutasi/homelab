services:
  beets:
    container_name: beets
    environment:
      - PUID={{ ansible_user_uid }}
      - PGID={{ ansible_user_gid }}
      - TZ={{ timezone }}
    hostname: {{ id }}-beets
    image: lscr.io/linuxserver/beets:{{ requested_image_version['beets'] }}
    ports:
      - {{ port_beets }}:8337
    restart: unless-stopped
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/config:/config
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/library:/music
{% for volume in docker_compose_extra_volumes %}
      - {{ volume.from }}:{{ volume.to }}
{% endfor %}
