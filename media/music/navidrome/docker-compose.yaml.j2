services:
  navidrome:
    container_name: navidrome
    environment:
      PGID: {{ ansible_user_gid }}
      PUID: {{ ansible_user_uid }}
      TZ: {{ timezone }}
      ND_SCANNER_ENABLED: false
      ND_SCANNER_SCANONSTARTUP: false
    hostname: {{ id }}-navidrome
    image: deluan/navidrome:{{ requested_image_version['navidrome'] }}
    ports:
      - {{ port_navidrome }}:4533
    restart: unless-stopped
    user: {{ ansible_user_uid }}:{{ ansible_user_gid }}
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/data:/data
{% for volume in docker_compose_extra_volumes %}
      - {{ volume.from }}:/music/{{ volume.to }}:ro
{% endfor %}
