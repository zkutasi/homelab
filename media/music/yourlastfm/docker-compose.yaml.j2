services:
  yourlastfm:
    container_name: yourlastfm
    environment:
      PGID: {{ ansible_user_gid }}
      PUID: {{ ansible_user_uid }}
      TZ: {{ timezone }}
      LASTFM_API_KEY: {{ yourlastfm_lastfm_api_key }}
      LASTFM_USERNAME: {{ lastfm_username }}
    hostname: {{ id }}-yourlastfm
    image: {{ requested_image_version['yourlastfm'] }}
    ports:
      - {{ port_yourlastfm }}:1533
    restart: unless-stopped
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/data:/app/data
