services:
  grimmory:
    container_name: grimmory
    depends_on:
      mariadb:
        condition: service_healthy
    environment:
      DATABASE_PASSWORD: {{ grimmory_db_user_password }}
      DATABASE_URL: jdbc:mariadb://mariadb:3306/booklore
      DATABASE_USERNAME: booklore
      GROUP_ID: {{ docker_gid }}
      PGID: {{ docker_gid }}
      PUID: {{ docker_uid }}
      TZ: {{ timezone }}
      USER_ID: {{ docker_uid }}
    healthcheck:
      interval: 60s
      retries: 5
      start_period: 60s
      test: wget -q -O - http://localhost:6060/api/v1/healthcheck
      timeout: 10s
    hostname: {{ id }}-grimmory
    image: grimmory/grimmory:v{{ requested_image_version['grimmory'] }}
    ports:
      - {{ port_grimmory }}:6060
    restart: unless-stopped
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/data:/app/data
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/bookdrop:/bookdrop
{% for volume in docker_compose_extra_volumes %}
      - {{ volume.from }}:/books/{{ volume.to }}:ro
{% endfor %}
  mariadb:
    container_name: grimmory-mariadb
    environment:
      PGID: {{ docker_gid }}
      PUID: {{ docker_uid }}
      TZ: {{ timezone }}
      MYSQL_ROOT_PASSWORD: {{ grimmory_db_root_password }}
      MYSQL_DATABASE: booklore
      MYSQL_USER: booklore
      MYSQL_PASSWORD: {{ grimmory_db_user_password }}
    healthcheck:
      interval: 5s
      retries: 10
      test: ["CMD", "mariadb-admin", "ping", "-h", "localhost"]
      timeout: 5s
    hostname: {{ id }}-grimmory-mariadb
    image: lscr.io/linuxserver/mariadb:{{ requested_image_version['mariadb'] }}
    ports:
      - {{ port_grimmory_mariadb }}:3306
    restart: unless-stopped
    volumes:
      - {{ docker_compose_rootdir }}/{{ docker_compose_projectname }}/mariadb/config:/config
