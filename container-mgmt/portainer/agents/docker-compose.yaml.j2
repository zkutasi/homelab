services:
  portainer-agent:
    container_name: portainer-agent
    environment:
      - TZ={{ timezone }}
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --spider --no-check-certificate https://localhost:9001/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    hostname: {{ id }}-portainer-agent
    image: portainer/agent:{{ requested_image_version['portainer-agent'] }}
    ports:
      - {{ port_portainer_agent }}:9001
    restart: unless-stopped
    volumes:
      - {{ docker_socket_path }}:/var/run/docker.sock
      - {{ docker_lib_path }}/volumes:/var/lib/docker/volumes
